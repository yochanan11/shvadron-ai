{
  "version": 2,
  "functions": {
    "api/chat.js": { "memory": 256, "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/mortgage-advisors", "destination": "https://mashcn.vercel.app" },
    { "source": "/mortgage-advisors/(.*)", "destination": "https://mashcn.vercel.app/$1" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
